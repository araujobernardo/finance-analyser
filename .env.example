VITE_ANTHROPIC_API_KEY=your_api_key_here
VITE_JIRA_BASE_URL=https://bernardo-araujo.atlassian.net
VITE_JIRA_EMAIL=your_atlassian_email@here.com
VITE_JIRA_API_TOKEN=your_api_token_here
VITE_JIRA_PROJECT_KEY=FA

# Feature 009 — Express Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Feature 008 — Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Feature 010 — Authentication
JWT_SECRET=your-secret-key-minimum-32-characters-long
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=auth@yourdomain.com
APP_URL=http://localhost:5173

# Feature 012 — Frontend Vercel deployment
# Frontend API base URL — set in .env.local for local dev, Vercel dashboard for production
# Local dev requires: VITE_API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001

# Feature 018 — Playwright E2E Tests
E2E_BASE_URL=http://localhost:5173
E2E_EMAIL=your-test-user@example.com
E2E_PASSWORD=your-test-password
