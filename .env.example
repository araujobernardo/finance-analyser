VITE_ANTHROPIC_API_KEY=your_api_key_here
VITE_JIRA_BASE_URL=https://bernardo-araujo.atlassian.net
VITE_JIRA_EMAIL=your_atlassian_email@here.com
VITE_JIRA_API_TOKEN=your_api_token_here
VITE_JIRA_PROJECT_KEY=FA

# Feature 008 — Database
# Use Supabase direct-connection URL (port 5432) for Render Web Service
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Feature 009 — Express Server
PORT=3001

# Feature 010 — Authentication
JWT_SECRET=your-secret-key-minimum-32-characters-long
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=auth@yourdomain.com

# APP_URL — base URL used in auth email links
# Production (Render Static Site): https://finance-analyser-dmff.onrender.com
APP_URL=https://finance-analyser-dmff.onrender.com

# CORS_ORIGIN — origin the Express API allows cross-origin requests from
# Set to the Render Static Site URL on the Render Web Service
CORS_ORIGIN=https://finance-analyser-dmff.onrender.com

# Feature 012 — API base URL (injected into the Vite browser bundle at build time)
# Local dev: http://localhost:3001
# Render (production): set to the Render Web Service URL, e.g. https://finance-analyser-api.onrender.com
VITE_API_URL=http://localhost:3001

# Feature 018 — Playwright E2E Tests
# E2E_BASE_URL — URL Playwright navigates to for E2E tests
# Production (Render): https://finance-analyser-dmff.onrender.com
E2E_BASE_URL=https://finance-analyser-dmff.onrender.com
E2E_EMAIL=your-test-user@example.com
E2E_PASSWORD=your-test-password
