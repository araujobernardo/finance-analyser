VITE_ANTHROPIC_API_KEY=your_api_key_here
VITE_JIRA_BASE_URL=https://bernardo-araujo.atlassian.net
VITE_JIRA_EMAIL=your_atlassian_email@here.com
VITE_JIRA_API_TOKEN=your_api_token_here
VITE_JIRA_PROJECT_KEY=FA

# Feature 008 — Database
# Use Supabase pooler URL (port 6543) for serverless environments (Vercel)
# Use direct URL (port 5432) for local dev or migration scripts
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres

# Feature 009 — Express Server
# PORT is only used when running locally (not on Vercel)
PORT=3001

# Feature 010 — Authentication
JWT_SECRET=your-secret-key-minimum-32-characters-long
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=auth@yourdomain.com
APP_URL=http://localhost:5173

# Feature 012 — API base URL
# Local dev: http://localhost:3001
# Vercel (production/preview): /api  (same-domain — no absolute URL needed)
VITE_API_URL=http://localhost:3001

# Vercel deployment protection bypass (E2E tests on preview deployments)
VERCEL_AUTOMATION_BYPASS_SECRET=your-bypass-secret

# Feature 018 — Playwright E2E Tests
E2E_BASE_URL=http://localhost:5173
E2E_EMAIL=your-test-user@example.com
E2E_PASSWORD=your-test-password
